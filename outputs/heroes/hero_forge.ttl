        rdfs:label "Attack Range"@en ;
        nydus:upgradeLevel "1"^^xsd:integer ;
        nydus:modifiesProperty "TurretAttackRange" ;
        nydus:bonusValue "10m" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Turret DPS"@en ;
        nydus:upgradeLevel "1"^^xsd:integer ;
        nydus:modifiesProperty "TurretDPS" ;
        nydus:bonusValue "10" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Charges"@en ;
        nydus:upgradeLevel "2"^^xsd:integer ;
        nydus:modifiesProperty "AbilityCharges" ;
        nydus:bonusValue "2" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Attack Speed Mult"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "AttackSpeedMult" ;
        nydus:bonusValue "30" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Lifetime"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "TurretLifetime" ;
        nydus:bonusValue "12" ;
    ] ;
    prov:wasDerivedFrom <scripts/abilities.vdata> .

