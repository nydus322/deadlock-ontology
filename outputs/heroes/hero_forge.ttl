    ] ;
    prov:wasDerivedFrom <scripts/abilities.vdata> .

# Ability: Shieldedsentry  (citadel_ability_shieldedsentry)
ability:Shieldedsentry
    a nydus:Ability ;
    rdfs:label "Shieldedsentry"@en ;
    nydus:internalKey "citadel_ability_shieldedsentry" ;
    nydus:abilityType "EAbilityType_Signature" ;
