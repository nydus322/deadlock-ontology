        nydus:bonusValue "1" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Max Cooldown Reduction"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "MaxCooldownReductionsFromHits" ;
        nydus:bonusValue "8" ;
    ] ;
