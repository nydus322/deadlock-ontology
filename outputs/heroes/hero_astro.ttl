        rdfs:label "Barrel Damage"@en ;
        nydus:upgradeLevel "2"^^xsd:integer ;
        nydus:modifiesProperty "BarrelDamage" ;
        nydus:bonusValue "58.5" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Charges"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "AbilityCharges" ;
        nydus:bonusValue "2" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Toss Duration"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "TossDuration" ;
        nydus:bonusValue "0.4" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Toss Speed"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "TossSpeed" ;
        nydus:bonusValue "140" ;
    ] ;
    prov:wasDerivedFrom <scripts/abilities.vdata> .

