# Ability: Splatter  (viscous_goo_grenade)
ability:ViscousGooGrenade
    a nydus:Ability ;
    rdfs:label "Splatter"@en ;
    nydus:internalKey "viscous_goo_grenade" ;
    nydus:abilityType "EAbilityType_Signature" ;
    nydus:activationType "CITADEL_ABILITY_ACTIVATION_INSTANT_CAST" ;
    nydus:hasProperty [
        a nydus:AbilityProperty ;
        rdfs:label "Cooldown"@en ;
        nydus:internalName "AbilityCooldown" ;
        nydus:baseValue "26"^^xsd:decimal ;
        nydus:primaryCategory cat:Cooldown ;
        nydus:categoryDeterminism "high" ;
        nydus:scalesStat stat:TechCooldown ;
        nydus:scaleFunction "scale_function_single_stat" ;
    ] ;
    nydus:hasProperty [
        a nydus:AbilityProperty ;
        rdfs:label "Damage"@en ;
        nydus:internalName "Damage" ;
        nydus:baseValue "70"^^xsd:decimal ;
        nydus:primaryCategory cat:Damage ;
        nydus:categoryDeterminism "high" ;
        nydus:scalesStat stat:TechPower ;
        nydus:scaleFactor "0.8"^^xsd:decimal ;
        nydus:scaleFunction "scale_function_tech_damage" ;
    ] ;
    nydus:hasProperty [
        a nydus:AbilityProperty ;
        rdfs:label "Slow Percent"@en ;
        nydus:internalName "SlowPercent" ;
        nydus:baseValue "35"^^xsd:decimal ;
        nydus:primaryCategory cat:Speed ;
        nydus:categoryDeterminism "low" ;
        nydus:categoryNote "Speed debuff — reduces target movement by percentage; filed under Speed as the affected stat" ;
        nydus:providesModifierType mv:MovementSpeedSlowPercent ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Damage"@en ;
        nydus:upgradeLevel "1"^^xsd:integer ;
        nydus:modifiesProperty "Damage" ;
        nydus:bonusValue "36" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Radius"@en ;
        nydus:upgradeLevel "1"^^xsd:integer ;
        nydus:modifiesProperty "Radius" ;
        nydus:bonusValue "2m" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Cooldown"@en ;
        nydus:upgradeLevel "2"^^xsd:integer ;
        nydus:modifiesProperty "AbilityCooldown" ;
        nydus:bonusValue "-14" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Max Bounces"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "MaxBounces" ;
        nydus:bonusValue "2" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Damage"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "Damage" ;
        nydus:bonusValue "1.1" ;
    ] ;
    prov:wasDerivedFrom <scripts/abilities.vdata> .

