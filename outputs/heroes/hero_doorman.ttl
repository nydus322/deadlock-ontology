@base            <http://nydus.gg/source/> .
@prefix nydus:   <http://nydus.gg/ontology#> .
@prefix hero:    <http://nydus.gg/ontology#hero/> .
@prefix ability: <http://nydus.gg/ontology#ability/> .
@prefix stat:    <http://nydus.gg/ontology#stat/> .
@prefix mv:      <http://nydus.gg/ontology#mv/> .
@prefix slot:    <http://nydus.gg/ontology#slot/> .
@prefix sf:      <http://nydus.gg/ontology#sf/> .
@prefix cat:     <http://nydus.gg/ontology#cat/> .
@prefix stage:   <http://nydus.gg/ontology#stage/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix schema:  <http://schema.org/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .

# ============================================================
# Property Categories  (cross-ability comparison anchors)
# ============================================================

cat:Charges  a nydus:PropertyCategory ; rdfs:label "Charges"@en .
cat:Cooldown  a nydus:PropertyCategory ; rdfs:label "Cooldown"@en .
cat:Damage  a nydus:PropertyCategory ; rdfs:label "Damage"@en .
cat:Duration  a nydus:PropertyCategory ; rdfs:label "Duration"@en .
cat:Healing  a nydus:PropertyCategory ; rdfs:label "Healing"@en .
cat:Range  a nydus:PropertyCategory ; rdfs:label "Range"@en .
cat:Speed  a nydus:PropertyCategory ; rdfs:label "Speed"@en .
cat:Stack  a nydus:PropertyCategory ; rdfs:label "Stack"@en .
cat:Stat  a nydus:PropertyCategory ; rdfs:label "Stat Modifier"@en .
cat:Unknown  a nydus:PropertyCategory ; rdfs:label "Unknown"@en .
cat:Weapon  a nydus:PropertyCategory ; rdfs:label "Weapon"@en .

# ============================================================
# Hero: Doorman  (hero_doorman  ID=69)
# ============================================================

hero:Holliday
    a nydus:Hero ;
    rdfs:label "Doorman"@en ;
    skos:altLabel "The Doorman"@en ;
    nydus:heroTag "Disorienting" ;
    nydus:heroTag "Map Control" ;
    nydus:heroTag "Mind Games" ;
    schema:identifier "69"^^xsd:integer ;
    nydus:internalKey "hero_doorman" ;
    nydus:developerStage stage:WIP ;
    nydus:isPlayerSelectable true ;
    nydus:isDisabled false ;
    nydus:complexity "1"^^xsd:integer ;
    nydus:heroType "ECitadelHeroType_Mystic" ;
    nydus:abilityResourceType "EResourceType_None" ;
    nydus:hasAbilityInSlot [ rdfs:label "Climb Rope"@en ; nydus:slot slot:AbilityClimbRope ; nydus:ability ability:ClimbRope ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Innate 1: Dash"@en ; nydus:slot slot:AbilityInnate1 ; nydus:ability ability:Dash ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Innate 2: Sprint"@en ; nydus:slot slot:AbilityInnate2 ; nydus:ability ability:Sprint ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Innate 3: Parry"@en ; nydus:slot slot:AbilityInnate3 ; nydus:ability ability:MeleeParry ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Jump"@en ; nydus:slot slot:AbilityJump ; nydus:ability ability:Jump ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Mantle"@en ; nydus:slot slot:AbilityMantle ; nydus:ability ability:Mantle ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Slide"@en ; nydus:slot slot:AbilitySlide ; nydus:ability ability:Slide ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Zip Line: Hyperline"@en ; nydus:slot slot:AbilityZipLine ; nydus:ability ability:ZipLine ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Zip Line Boost: Zipline Boosted"@en ; nydus:slot slot:AbilityZipLineBoost ; nydus:ability ability:ZiplineBoost ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Ability 1: Call Bell"@en ; nydus:slot slot:Signature1 ; nydus:ability ability:DoormanBomb ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Ability 2: Doorman Doorway"@en ; nydus:slot slot:Signature2 ; nydus:ability ability:DoormanDoorway ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Ability 3: Doorman Luggage Cart"@en ; nydus:slot slot:Signature3 ; nydus:ability ability:DoormanLuggageCart ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Ultimate: Doorman Hotel"@en ; nydus:slot slot:Signature4 ; nydus:ability ability:DoormanHotel ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Melee"@en ; nydus:slot slot:WeaponMelee ; nydus:ability ability:MeleeDoorman ] ;
    nydus:hasAbilityInSlot [ rdfs:label "Primary Weapon: Doorman Set"@en ; nydus:slot slot:WeaponPrimary ; nydus:ability ability:WeaponDoormanSet ] ;
    nydus:startingMaxMoveSpeed "7.9"^^xsd:decimal ;
    nydus:startingSprintSpeed "1.6"^^xsd:decimal ;
    nydus:startingMaxHealth "765"^^xsd:decimal ;
    nydus:startingBaseHealthRegen "1"^^xsd:decimal ;
    nydus:startingStamina "3"^^xsd:decimal ;
    nydus:startingStaminaRegenPerSecond "0.222222"^^xsd:decimal ;
    nydus:startingReloadSpeed "1"^^xsd:decimal ;
    nydus:startingLightMeleeDamage "50"^^xsd:decimal ;
    nydus:startingHeavyMeleeDamage "116"^^xsd:decimal ;
    nydus:startingTechDuration "1"^^xsd:decimal ;
    nydus:startingTechRange "1"^^xsd:decimal ;
    prov:wasDerivedFrom <scripts/heroes.vdata> .

# Ability: Dash  (citadel_ability_dash)
ability:Dash
    a nydus:Ability ;
    rdfs:label "Dash"@en ;
    nydus:internalKey "citadel_ability_dash" ;
    nydus:abilityType "EAbilityType_Innate" ;
    nydus:activationType "CITADEL_ABILITY_ACTIVATION_INSTANT_CAST" ;
    nydus:hasProperty [
        a nydus:AbilityProperty ;
        rdfs:label "Duration"@en ;
        nydus:internalName "AbilityDuration" ;
        nydus:baseValue "0.6"^^xsd:decimal ;
        nydus:primaryCategory cat:Duration ;
        nydus:categoryDeterminism "high" ;
        nydus:scalesStat stat:TechDuration ;
        nydus:scaleFunction "scale_function_single_stat" ;
    ] ;
    prov:wasDerivedFrom <scripts/abilities.vdata> .

