        rdfs:label "Toss Duration"@en ;
        nydus:upgradeLevel "2"^^xsd:integer ;
        nydus:modifiesProperty "TossDuration" ;
        nydus:bonusValue "1" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Stomp Damage Per Meter Primary"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "StompDamagePerMeterPrimary" ;
        nydus:bonusValue "0.03255" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Stomp Damage Per Meter Primary"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "StompDamagePerMeterPrimary" ;
        nydus:bonusValue "113" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Stomp Damage Per Meter Secondary"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "StompDamagePerMeterSecondary" ;
        nydus:bonusValue "0.008137" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Stomp Damage Per Meter Secondary"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "StompDamagePerMeterSecondary" ;
        nydus:bonusValue "113" ;
    ] ;
    prov:wasDerivedFrom <scripts/abilities.vdata> .

