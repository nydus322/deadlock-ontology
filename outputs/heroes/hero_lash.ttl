# Ability: Death Slam  (citadel_ability_lash_ultimate)
ability:LashUltimate
    a nydus:Ability ;
    rdfs:label "Death Slam"@en ;
    nydus:internalKey "citadel_ability_lash_ultimate" ;
    nydus:abilityType "EAbilityType_Ultimate" ;
    nydus:activationType "CITADEL_ABILITY_ACTIVATION_INSTANT_CAST" ;
    nydus:hasProperty [
        a nydus:AbilityProperty ;
        rdfs:label "Cooldown"@en ;
        nydus:internalName "AbilityCooldown" ;
        nydus:baseValue "150"^^xsd:decimal ;
        nydus:primaryCategory cat:Cooldown ;
        nydus:categoryDeterminism "high" ;
        nydus:scalesStat stat:TechCooldown ;
        nydus:scaleFunction "scale_function_single_stat" ;
    ] ;
    nydus:hasProperty [
        a nydus:AbilityProperty ;
        rdfs:label "Cast Range"@en ;
        nydus:internalName "AbilityCastRange" ;
        nydus:baseValue "20m" ;
        nydus:primaryCategory cat:Range ;
        nydus:categoryDeterminism "high" ;
        nydus:scalesStat stat:TechRadius ;
        nydus:scaleFunction "scale_function_single_stat" ;
    ] ;
    nydus:hasProperty [
        a nydus:AbilityProperty ;
        rdfs:label "Slow Percent"@en ;
        nydus:internalName "SlowPercent" ;
        nydus:baseValue "50"^^xsd:decimal ;
        nydus:primaryCategory cat:Speed ;
        nydus:categoryDeterminism "low" ;
        nydus:categoryNote "Speed debuff — reduces target movement by percentage; filed under Speed as the affected stat" ;
        nydus:providesModifierType mv:MovementSpeedSlowPercent ;
    ] ;
    nydus:hasProperty [
        a nydus:AbilityProperty ;
        rdfs:label "Slow Duration"@en ;
        nydus:internalName "SlowDuration" ;
        nydus:baseValue "4"^^xsd:decimal ;
        nydus:primaryCategory cat:Duration ;
        nydus:secondaryCategory cat:Speed ;
        nydus:categoryDeterminism "low" ;
        nydus:categoryNote "Duration of a speed debuff — temporal in form, speed in function" ;
        nydus:scalesStat stat:TechDuration ;
        nydus:scaleFunction "scale_function_single_stat" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Throw Distance"@en ;
        nydus:upgradeLevel "1"^^xsd:integer ;
        nydus:modifiesProperty "ThrowDistance" ;
        nydus:bonusValue "12m" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Cooldown"@en ;
        nydus:upgradeLevel "2"^^xsd:integer ;
        nydus:modifiesProperty "AbilityCooldown" ;
        nydus:bonusValue "-40" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Stun Duration"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "StunDuration" ;
        nydus:bonusValue "1.2" ;
    ] ;
    nydus:hasUpgrade [
        a nydus:AbilityUpgrade ;
        rdfs:label "Cast Range"@en ;
        nydus:upgradeLevel "3"^^xsd:integer ;
        nydus:modifiesProperty "AbilityCastRange" ;
        nydus:bonusValue "6m" ;
    ] ;
    prov:wasDerivedFrom <scripts/abilities.vdata> .

# ============================================================
# Vocabulary labels  (stat / slot / scale-function / modifier / shared abilities)
# ============================================================

ability:ClimbRope  rdfs:label "Climb Rope"@en .
ability:Jump  rdfs:label "Jump"@en .
ability:Mantle  rdfs:label "Mantle"@en .
ability:MeleeLash  rdfs:label "Melee"@en .
ability:Slide  rdfs:label "Slide"@en .
ability:WeaponLashSet  rdfs:label "Lash Set"@en .
ability:ZipLine  rdfs:label "Hyperline"@en .
ability:ZiplineBoost  rdfs:label "Zipline Boosted"@en .
stat:ParryCooldown  a nydus:Stat ; rdfs:label "Parry Cooldown"@en .
stat:TechCooldown  a nydus:Stat ; rdfs:label "Ability Cooldown"@en .
stat:TechDuration  a nydus:Stat ; rdfs:label "Ability Duration"@en .
stat:TechPower  a nydus:Stat ; rdfs:label "Spirit Power"@en .
stat:TechRadius  a nydus:Stat ; rdfs:label "Tech Radius"@en .
stat:TechRange  a nydus:Stat ; rdfs:label "Ability Range"@en .
slot:AbilityClimbRope  a nydus:Slot ; rdfs:label "Climb Rope"@en .
slot:AbilityInnate1  a nydus:Slot ; rdfs:label "Innate 1"@en .
slot:AbilityInnate2  a nydus:Slot ; rdfs:label "Innate 2"@en .
slot:AbilityInnate3  a nydus:Slot ; rdfs:label "Innate 3"@en .
slot:AbilityJump  a nydus:Slot ; rdfs:label "Jump"@en .
slot:AbilityMantle  a nydus:Slot ; rdfs:label "Mantle"@en .
slot:AbilitySlide  a nydus:Slot ; rdfs:label "Slide"@en .
slot:AbilityZipLine  a nydus:Slot ; rdfs:label "Zip Line"@en .
slot:AbilityZipLineBoost  a nydus:Slot ; rdfs:label "Zip Line Boost"@en .
slot:Signature1  a nydus:Slot ; rdfs:label "Ability 1"@en .
slot:Signature2  a nydus:Slot ; rdfs:label "Ability 2"@en .
slot:Signature3  a nydus:Slot ; rdfs:label "Ability 3"@en .
slot:Signature4  a nydus:Slot ; rdfs:label "Ultimate"@en .
slot:WeaponMelee  a nydus:Slot ; rdfs:label "Melee"@en .
slot:WeaponPrimary  a nydus:Slot ; rdfs:label "Primary Weapon"@en .
