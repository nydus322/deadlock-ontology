# Ability: Lash Down Strike  (citadel_ability_lash_down_strike)
ability:LashDownStrike
    a nydus:Ability ;
    rdfs:label "Lash Down Strike"@en ;
    nydus:internalKey "citadel_ability_lash_down_strike" ;
    nydus:abilityType "EAbilityType_Signature" ;
